      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "x=np.array([[1,1,2],[1,2,3],[1,3,4]])\n",
        "y=np.array([[1],[2],[3]])\n",
        "xt=x.T\n",
        "xtx=xt@x\n",
        "lambdaI=np.array([[1,0,0],[0,1,0],[0,0,1]])\n",
        "A=xtx+lambdaI\n",
        "xty=xt@y\n",
        "invm=np.linalg.inv(A)\n",
        "values=invm@xty\n",
        "values"
      ],
